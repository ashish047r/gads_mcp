# -------------------------------------------------------
# Google Ads MCP Server — Environment Configuration
# Copy this file to .env and fill in your values.
# -------------------------------------------------------

# Path to your OAuth 2.0 client secret JSON downloaded from Google Cloud Console.
# Go to: https://console.cloud.google.com/apis/credentials
# Create an "OAuth 2.0 Client ID" of type "Desktop app", then download the JSON.
GOOGLE_ADS_OAUTH_CONFIG_PATH=/full/path/to/client_secret_XXXXX.apps.googleusercontent.com.json

# Your Google Ads Developer Token.
# Found in: Google Ads → Tools → API Centre
GOOGLE_ADS_DEVELOPER_TOKEN=your_developer_token_here

# (Optional) Manager (MCC) account ID — only needed if you manage multiple accounts.
# GOOGLE_ADS_LOGIN_CUSTOMER_ID=1234567890
